{% include 'form.snap.jinja' %}
<template>
  <div class="app-container">

    {% include 'query.snap.jinja' %}

    <el-row :gutter="10" class="mb8">
      <el-col :span="1.5">
        <el-button
            type="primary"
            plain
            icon="Plus"
            @click="handleAdd"
            v-hasPermi="['${{ permissionPrefix }}:add']"
        >新增
        </el-button>
      </el-col>
      {% if not isTree %}
        <el-col :span="1.5">
          <el-button
              type="danger"
              plain
              icon="Delete"
              :disabled="multiple"
              @click="handleDelete"
              v-hasPermi="['${{ permissionPrefix }}:remove']"
          >删除
          </el-button>
        </el-col>
        <el-col :span="1.5">
          <el-button
              type="warning"
              plain
              icon="Download"
              @click="handleExport"
              v-hasPermi="['${{ permissionPrefix }}:export']"
          >导出
          </el-button>
        </el-col>
      {% endif %}
      {% if isTree %}
        <el-col :span="1.5">
          <el-button
              type="info"
              plain
              icon="Sort"
              @click="toggleExpandAll"
          >展开/折叠
          </el-button>
        </el-col>
      {% endif %}
      <right-toolbar v-model:showSearch="showSearch" @queryTable="getList"
                     {% if swOpt.showColumns %}:columns="columns"{% endif %}></right-toolbar>
    </el-row>
    {% macro tableColumnAttrs(column) -%}
      label="${{ column.comment }}" {% if column.sortable %} sortable="custom" {% endif %} align="center"
      prop="${{ column.rustField|camel }}" {% if swOpt.showColumns and column.isList %} v-if="columnMap.${{ column.rustField|camel }}" {% endif %}
    {%- endmacro %}
    <el-table v-loading="loading" {% if swOpt.fixHeader %}v-fixedTableHeight{% endif %}
              :data="${{ businessName }}s"
        {% if isTree %}  row-key="${{ tableOptions.treeCode|camel }}"
              :default-expand-all="isExpandAll"
              :tree-props="{children: 'children', hasChildren: 'hasChildren'}"
              v-if="refreshTable"
        {% else %}
              @selection-change="handleSelectionChange"
          {% if hasSortColumn %}  @sort-change="sortChange" {% endif %}
        {% endif %}

    >

      <el-table-column type="selection" width="55" align="center"/>
      {% if isSub %}
        <el-table-column align="center" label="${{ tableOptions.mainTableDisLabel }}"
                         prop="${{ tableOptions.mainTableDisColName|camel }}"/>
      {% endif %}
      {% for column in columns %}
        {% if column.isList %}
          {% if column.htmlType == "datetime" or column.htmlType == "date" %}
            <el-table-column ${{ tableColumnAttrs(column) }}/>
          {% elif column.dictType %}
            <el-table-column ${{ tableColumnAttrs(column) }}>
              <template #default="{row}">
                <dict-tag :options="${{ column.dictType }}" :value="row.${{ column.rustField|camel }}"/>
              </template>
            </el-table-column>
          {% elif column.htmlType == "select"  and  column.hasFk %}
            <el-table-column ${{ tableColumnAttrs(column) }} :formatter="${{ column.rustField|camel }}Format"/>
          {% elif column.htmlType == "imageUpload" %}
            <el-table-column ${{ tableColumnAttrs(column) }}>
              <template #default="{row}">
                <el-image preview-teleported
                          src="/images/preview.svg"
                          style="width: 20px;height: 20px;cursor: pointer"
                          :preview-src-list="row.${{ column.rustField|camel }}.map(url=>baseUrl+url)"
                          v-if="row.${{ column.rustField|camel }}&&row.${{ column.rustField|camel }}.length>0"
                          lazy
                />

              </template>
            </el-table-column>
          {% elif column.rustType == "String" %}
            <el-table-column ${{ tableColumnAttrs(column) }}
                             {% if column.maxLength>200 or column.maxLength==0 %}show-overflow-tooltip{% endif %}/>
          {% elif column.rustField|camel %}
            <el-table-column ${{ tableColumnAttrs(column) }}/>
          {% endif %}
        {% endif %}
      {% endfor %}
      <el-table-column label="操作" align="center" class-name="small-padding fixed-width">
        <template #default="{row}">
          {% if isTree %}
          <el-button type="primary" text icon="Plus" @click="handleAdd(row)"
                     v-hasPermi="['${{ permissionPrefix }}:add']">新增
          </el-button>
          {% endif %}
          <el-button type="primary" text icon="Edit" @click="handleUpdate(row)"
                     v-hasPermi="['${{ permissionPrefix }}:edit']">修改
          </el-button>
          <el-button type="danger" text icon="Delete" @click="handleDelete(row)"
                     v-hasPermi="['${{ permissionPrefix }}:remove']">删除
          </el-button>
        </template>
      </el-table-column>
    </el-table>
    {% if not isTree %}
      <pagination v-show="total>0" :total="total" v-model:page="queryParams.pageNum"
                  v-model:limit="queryParams.pageSize" @pagination="getList"/>
    {% endif %}
    <!-- 添加或修改${{functionName}}对话框 -->
    <el-dialog :title="title" v-model="open" {% if insertEditCnt>=8 %}width="650px"{% else %}
               width="500px"{% endif %}>
      {% if insertEditCnt>=12 %}
        <el-scrollbar height="600px" class="pr-2"> {% endif %}
      <el-form ref="${{ businessName }}Ref" :model="form" :rules="rules"  {% if insertEditCnt>=12 %}
               class="mr-2"  {% endif %}>
        {% if insertEditCnt>=8 %}
          <el-row :gutter="15">
        {% endif %}
        {% if isSub %}
          {% if insertEditCnt>=8 %}
            <el-col :span="12"> {% endif %}
        <el-form-item label="${{ tableOptions.mainTableDisLabel }}">
          <el-input v-model="form.${{ tableOptions.mainTableDisColName|camel }}" disabled/>
        </el-form-item>
        {% if insertEditCnt>=8 %}</el-col> {% endif %}
        {% endif %}
        {% for column in columns %}
          ${{ formItemRender(column,insertEditCnt>=8,'form','') }}
        {% endfor %}
        {% if isO2O %}
          <el-divider content-position="center">${{ subTable.functionName }}信息</el-divider>

          <div class="w-100 mb-2 ml-2">
            <el-button
                type="primary"
                plain
                small
                icon="Plus"
                @click="new${{ subTable.BusinessName }}"
                v-if="!form.${{ subTable.businessName }}"
                v-hasPermi="['${{ subTable.permissionPrefix }}:add']"
            >新增
            </el-button>
            <el-button
                type="danger"
                plain
                small
                icon="Delete"
                v-if="form.${{ subTable.businessName }}"
                @click="form.${{ subTable.businessName }}=undefined"
                v-hasPermi="['${{ subTable.permissionPrefix }}:remove']"
            >删除
            </el-button>
          </div>
          <template v-if="form.${{ subTable.businessName }}">
            {% for column in subTable.columns %}
              ${{ formItemRender(column,insertEditCnt>=8,'form',subTable.businessName) }}
            {% endfor %}
          </template>
        {% endif %}

        {% if isM2M %}
          <el-col :span="12">
            <el-form-item label="${{ subTable.functionName }}" prop="${{ subTable.pkColumn.rustField|camel }}s">
              <el-select v-model="form.${{ subTable.pkColumn.rustField|camel }}s" placeholder="请选择" clearable
                         :options="all${{ subTable.BusinessName }}s" multiple
                         :props="{value:'${{ subTable.pkColumn.rustField|camel }}',label:'${{ tableOptions.subTableDisColName|camel }}'}">
              </el-select>
            </el-form-item>
          </el-col>
        {% endif %}
        {% if isO2M %}
          <el-divider content-position="center">${{ subTable.functionName }}信息</el-divider>
          <el-table :data="form.${{ subTable.businessName }}s"
                    ref="${{ subTable.BusinessName }}">
            <el-table-column label="序号" align="center" prop="index" width="50">
              <template #default="{row,$index}">
                <div class="subTableDelete">
                  <el-button icon="Delete" circle text type="danger"
                             @click="handleDelete${{ subTable.BusinessName }}(row.${{ subTable.pkColumn.rustField|camel }},$index)"></el-button>
                  <span>{{$index+1}}</span>
                </div>

              </template>
            </el-table-column>
            {% for column in subTable.columns %}
              {% if column.isPk  or  column.rustField|camel  ==  tableOptions.subTableColName|camel %}

              {% elif not column.special and not column.isPk and (column.isEdit or column.isInsert) %}
                <el-table-column label="${{ column.comment }}" prop="${{ column.rustField|camel }}">
                  <template #default="{row}">

                   ${{inputRender(column,'row',column.rustField|camel)}}
                  </template>
                </el-table-column>
              {% endif %}
            {% endfor %}
            <template #append>
              <el-button type="primary" icon="Plus" size="small" @click="handleAdd${{subTable.BusinessName}}" class="m-2">添加一行
              </el-button>
            </template>
          </el-table>
        {% endif %}
        {% if insertEditCnt>=8 %}</el-row>{% endif %}
      </el-form>
      {% if insertEditCnt>=12 %} </el-scrollbar> {% endif %}
      <template #footer>
        <el-button type="primary" @click="submitForm">确 定</el-button>
        <el-button @click="cancel">取 消</el-button>
      </template>
    </el-dialog>
  </div>
</template>

<script setup name="${{ BusinessName }}">
    {% if hasImageInList %}
        const baseUrl = import.meta.env.VITE_APP_BASE_API;
    {% endif %}
    import {
        list${{BusinessName}},
        get${{BusinessName}},
        del${{BusinessName}},
        add${{BusinessName}},
        update${{BusinessName}}
    } from "@/api/${{moduleName}}/${{businessName}}";

    import {ElMessage, ElMessageBox} from "element-plus";

    {% if isTree %}
        import {handleTree} from "@/utils/ruoyi.js";
    {% endif %}
    {% if dicts!="" %}
        import {useDict} from "@/utils/dict.js";
        const {${{dicts|replace("'","")}}} = useDict(${{dicts}});
    {% endif %}

    const ${{businessName}}s = ref([]);


    const open = ref(false);
    const loading = ref(true);
    const showSearch = ref(true);
    const ids = ref([]);
    const single = ref(true);
    const multiple = ref(true);
    {% if not isTree %}
        const total = ref(0);
    {% else %}
        const ${{businessName}}Options = ref([]);
        const isExpandAll = ref(true);
        const refreshTable = ref(true);
    {% endif %}

    const title = ref("");
    const queryParams = ref({
        pageNum: 1,
        pageSize: 10,
        {% if hasBetween %}
            params: {},
        {% endif %}

        {% for column in columns %}
            {% if column.query %}
                ${{ column.rustField|camel }}: null,
            {% endif %}
        {% endfor %}
    });
    {% include 'rules.snap.jinja' %}
    const rules = {
        {% for column in columns %}
            ${{buildRules(column,'')}}
        {% endfor %}
        {% if isO2O %}
            {% for column in subTable.columns %}
                ${{buildRules(column,subTable.businessName)}}
            {% endfor %}
        {% endif %}
    }

    const form = ref({});
    const isEdit = computed(() => {
        return form.value.${{pkColumn.rustField|camel}};
    })

    /** 查询${{functionName}}列表 */
    function getList() {
        loading.value = true;
        {% if hasSortColumn %}
            delete queryParams.value.orderByColumn;
            delete queryParams.value.isAsc;

            // if (this.sortColumn) {
            //   const {prop, order} = this.sortColumn;
            //   if(prop and order){
            //     this.queryParams.orderByColumn = prop;
            //     this.queryParams.isAsc = order;
            //   }
            // }
        {% endif %}
        list${{BusinessName}}(queryParams.value).then(response => {
            {% if isTree %}
                ${{businessName}}s.value = handleTree(response.data, "${{tableOptions.treeCode|camel}}", "${{tableOptions.treeParentCode|camel}}");
            {% else %}
                ${{businessName}}s.value = response.rows;
                total.value = response.total;
            {% endif %}
            loading.value = false;
        });
    }

    // 取消按钮
    function cancel() {
        open.value = false;
        reset();
    }

    const ${{businessName}}Ref = ref();


    {% macro defaultForm(column) -%}
        {% if (tableOptions.softDelete and tableOptions.softDeleteColumn==column.rustField) or column.special %}
        {% elif column.defVal is not none %}
            {% if column.rustType == "String" or column.rustType == "char" %}
              ${{ column.rustField|camel }}: "${{ column.defVal}}",
            {% elif column.rustType == "bool"%}
              ${{ column.rustField|camel }}:{% if column.defVal=='0'%} false{% else %}true{% endif %},
            {% else %}
              ${{ column.rustField|camel }}: ${{ column.defVal}},
            {% endif %}
        {% elif column.htmlType == "checkbox" %}
          ${{ column.rustField|camel }}: [],
        {% else %}
            ${{ column.rustField|camel }}: null,
        {% endif %}
    {%- endmacro %}
    // 表单重置
    function reset() {
        form.value = {
            {% for column in columns %}
                ${{defaultForm(column)}}
            {% endfor %}
            {% if isO2M %}
                ${{ subTable.businessName }}s: []
            {% endif %}
        };

        ${{businessName}}Ref.value && ${{businessName}}Ref.value.resetFields();
    }
    {% if isO2O %}
        function new${{ subTable.BusinessName }}() {
            let ${{ subTable.businessName }} = {
                {% for column in subTable.columns %}
                    ${{defaultForm(column)}}
                {% endfor %}
            }
            form.value.${{ subTable.businessName }} = ${{ subTable.businessName }};
        }
    {% endif %}
    /** 搜索按钮操作 */
    function handleQuery() {
        queryParams.value.pageNum = 1;
        getList();
    }

    const queryRef = ref();

    /** 重置按钮操作 */
    function resetQuery() {
        queryRef.value.resetFields();
        queryParams.value.params = {};
        handleQuery();
    }

    // 多选框选中数据
    function handleSelectionChange(selection) {
        ids.value = selection.map(item => item.${{pkColumn.rustField|camel}});
        single.value = selection.length != 1;
        multiple.value = !selection.length;
    }

    /** 新增按钮操作 */
    function handleAdd({% if isTree %}row{% endif %}) {
        reset();
        {% if isTree %}
            if (row != null && row.${{tableOptions.treeCode|camel}}) {
                form.value.${{tableOptions.treeParentCode|camel}} = row.${{tableOptions.treeCode|camel}};
            } else {
                form.value.${{tableOptions.treeParentCode|camel}} = '0';
            }
        {% endif %}
        open.value = true;
        title.value = "添加${{functionName}}";
    }

    /** 修改按钮操作 */
    function handleUpdate(row) {
        reset();
        const _${{pkColumn.rustField|camel}} = row.${{pkColumn.rustField|camel}} || ids.value
        get${{BusinessName}}(_${{pkColumn.rustField|camel}}).then(response => {
            form.value = response.data;
            {% for column in columns %}
                {% if column.htmlType == "checkbox" %}
                    form.value.${{ column.rustField|camel }} = form.value.${{column.rustField|camel}}.split(",");
                {% endif %}
            {% endfor %}
            open.value = true;
            title.value = "修改${{functionName}}";
        });
    }

    /** 提交按钮 */
    function submitForm() {
        ${{businessName}}Ref.value.validate(valid => {
            if (valid) {
                {% for column in columns %}
                    {% if column.htmlType == "checkbox" %}
                        form.value.${{column.rustField|camel}} = form.value.${{column.rustField|camel}}.join(",");
                    {% endif %}
                {% endfor %}
                if (form.value.${{pkColumn.rustField|camel}} != null) {
                    update${{BusinessName}}(form.value).then(response => {
                        ElMessage.success("修改成功");
                        open.value = false;
                        getList();
                        {% if isTree %}getTreeselect();{% endif %}
                    });
                } else {
                    add${{BusinessName}}(form.value).then(response => {
                        ElMessage.success("新增成功");
                        open.value = false;
                        getList();
                        {% if isTree %}getTreeselect();{% endif %}
                    });
                }
            }
        });
    }

    {% if isTree %}
        /** 展开/折叠操作 */
        function toggleExpandAll() {
            refreshTable.value = false;
            isExpandAll.value = !isExpandAll.value;
            nextTick(() => {
                refreshTable.value = true;
            });
        }
        /** 查询${{functionName}}下拉树结构 */
        function getTreeselect() {
            list${{BusinessName}}({}).then(response => {
                ${{businessName}}Options.value = [];
                const data = {
                    ${{tableOptions.treeCode|camel}}: '0',
                    ${{tableOptions.treeName|camel}}: '顶级节点',
                    children: []
                };
                data.children = handleTree(response.data, "${{tableOptions.treeCode|camel}}", "${{tableOptions.treeParentCode|camel}}");
                ${{businessName}}Options.value.push(data);
            });
        }
    {% endif %}

    /** 删除按钮操作 */
    function handleDelete(row) {
        const _${{pkColumn.rustField|camel}}s = row.${{pkColumn.rustField|camel}} || ids.value;
        ElMessageBox.confirm('是否确认删除${{functionName}}编号为"' + _${{pkColumn.rustField|camel}}s + '"的数据项？').then(function () {
            return del${{BusinessName}}(_${{pkColumn.rustField|camel}}s);
        }).then(() => {
            getList();
            ElMessage.success.success("删除成功");
        }).catch(() => {
        });
    }

    {% if isO2M %}
        /** ${{subTable.functionName}}添加按钮操作 */
        function handleAdd${{subTable.BusinessName}}() {
            let obj = {};

            form.value.${{ subTable.businessName }}s.push(obj);
        }

        /** ${{subTable.functionName}}删除按钮操作 */
        function handleDelete${{subTable.BusinessName}}(${{subTable.pkColumn.rustField|camel}}, idx) {
            if (!Array.isArray(form.value.deleted${{subTable.pkColumn.rustField|upperCamel}}s)) {
                form.value.deleted${{subTable.pkColumn.rustField|upperCamel}}s = [];
            }
            ${{subTable.pkColumn.rustField|camel}} && form.value.deleted${{subTable.pkColumn.rustField|upperCamel}}s.push(${{subTable.pkColumn.rustField|camel}});

            form.value.${{subTable.businessName }}s.splice(idx, 1);
        }


    {% endif %}

    import {download} from "@/utils/request.js";

    /** 导出按钮操作 */
    function handleExport() {
        download('${{moduleName}}/${{businessName}}/export', {
            ...queryParams.value
        }, `${{businessName}}_${new Date().getTime()}.xlsx`)
    }

    {% if isM2M %}
        import {
            list${{subTable.BusinessName}}AllSimple
        } from "@/api/${{subTable.moduleName}}/${{subTable.businessName}}";

        const all${{subTable.BusinessName}}s = ref([])
        function handleListAll() {
            list${{subTable.BusinessName}}AllSimple().then((res) => {
                all${{subTable.BusinessName}}s.value = res.data;
            })
        }
        handleListAll();
    {% endif %}

    {% if swOpt.showColumns %}
        //region 显示隐藏列
        const columns_ = [
            {% for column in columns %}
                {% if column.isList %}
                    {
                        label: "${{column.comment}}",
                        key: "${{column.rustField|camel}}",
                        visible: {% if column.isTable %}true{% else %}false{% endif %}
                    },
                {% endif %}
            {% endfor %}
        ]

        import useShowColumns from "@/utils/useShowColumns.js";
        const {columns, columnMap} = useShowColumns(columns_, "${{businessName}}");
        //endregion
    {% endif %}
    getList();
    {% if isTree %}getTreeselect();{% endif %}
</script>
